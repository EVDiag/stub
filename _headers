# Cloudflare Pages header rules.
# Serve Apple's App Site Association file as JSON. Apple's CDN tolerates
# octet-stream, but application/json is the correct, unambiguous type.
/.well-known/apple-app-site-association
  Content-Type: application/json

# Baseline security headers, site-wide. (No CSP yet on purpose: the pages carry
# inline styles/scripts and Google Fonts - a strict policy needs its own pass.)
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Strict-Transport-Security: max-age=15552000
